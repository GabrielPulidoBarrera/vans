import { Interface } from "node:readline";
import TanstackTable from "../components/Dashboard/TanstackTable.tsx";
import Layout from "@layouts/Layout.astro";
import CarritoProductoContenedor from "@components/Carrito/CarritoProductoContenedor.astro";

let APIROCKET_ECOMMERCE_TOKEN = process.env.APIROCKET_ECOMMERCE_TOKEN;
if (!APIROCKET_ECOMMERCE_TOKEN) {
    APIROCKET_ECOMMERCE_TOKEN = import.meta.env.APIROCKET_ECOMMERCE_TOKEN;
}

let myQuery = `query MyQuery {
  Orders {
    correo
    codigoPedido
    cart
    sent
    id
    createdAt
    telephone
  }
}
`;

interface InterfazFecha{
    createdAt: string
}


async function fetchApirocket(query: String) {
    const options = {
        method: "POST",
        headers: {
            "Content-Type": "application/json",
            Authorization: `Bearer ${APIROCKET_ECOMMERCE_TOKEN}`,
        },
        body: JSON.stringify({ query }),
    };

    const data = await fetch("https://graphql.apirocket.io", options).then(
        (response) => response.json(),
    );
    //console.log(data);
    return data;
}

let data = (await fetchApirocket(myQuery)).data.Orders;
//console.log(data);


data.map((e: InterfazFecha) => {
    e.createdAt = new Date(Date.parse(e.createdAt)).toLocaleString(
        "es-ES",
    );
});

//let carrito = data.cart
