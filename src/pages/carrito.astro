    <a href="/checkout">
      <GeneralBotonPago texto="Confirmar pedido"></GeneralBotonPago>
    </a>
</div>

<div class="max-w-7xl mx-auto md:px-6">



  <div class="md:flex md:flex-col items-center col-span-8 min-w-4/5">
<div class="w-full">
  <CarritoSuperior cantidad="5"></CarritoSuperior>
</div>
    <div class="md:flex w-full grow">
      <!--izquierda-->

<div class="flex flex-col md:w-3/5 ml-0 sm:ml-6 md:ml-10 lg:ml-15">



  
    <template x-for="producto in carrito"  >
      <CarritoProducto></CarritoProducto>
    </template>

   
    <div class="hidden md:block">
      <ProductoCarrusel ArrayRecomendaciones={arrayProductos} />
    </div>
  </div>
  <!-- derecha -->
  <div class="md:w-2/5 px-5 mb-2">
    <CarritoLateral numeroProducto="4" precio="20" />

<div class="hidden md:block">
  <GeneralBotonApple></GeneralBotonApple>
  <a href="/checkout">
    <GeneralBotonPago texto="Confirmar pedido"></GeneralBotonPago>
  </a>
</div>
  </div>
</div>
  </div>


  </div>

</div>


      {arrayProductos.map((Valor: any) => (

  <ProductoTallas
      tallas={respuesta.data.Sizes[respuesta.data.Sizes.findIndex((e: any) => {
  return e.tag == Valor.tag;
})]}
      producto={Valor}
      price={Valor.price}
    />))}

  
  </Layout>
  

<script>

  import clonar from "@utils/localStorage"
import Alpine from "alpinejs";
  

const stored = localStorage.getItem("carrito");
let carrito
if (stored!=null){
  carrito = JSON.parse(stored)
}


let objetoAlpineCarrito = {

  carrito: carrito,
  pagina: 'carrito',
    refreshCarrito() {
    const stored = localStorage.getItem('carrito');
    this.carrito = stored ? JSON.parse(stored) : [];
  },
   removeFromCarrito(producto: any) {
    this.carrito = this.carrito.filter((item: any) => 
      !(item.id === producto.id && item.talla === producto.talla && item.color === producto.color)
    );
    localStorage.setItem('carrito', JSON.stringify(this.carrito));
  }
}
Alpine.data('objetoAlpineCarrito', () => objetoAlpineCarrito)

//  clonar()



let cantidad = 0;
let precio = 0;
    if(!Alpine.store('precioCantidad')){

      carrito.map((e: any) => {
        cantidad+=1;
        precio += e.cantidad*e.precio;

      })

      Alpine.store('precioCantidad', { cantidad: cantidad, precio: precio});
    }
  ;

</script>