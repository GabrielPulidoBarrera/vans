<Layout>

    <input type="checkbox" name="mostrarEnvio" id="mostrarEnvio" checked> <label for="mostrarEnvio">Mostrar enviado</label>


    <table class="w-full *:text-center">
        <thead class="bg-gray-200">
            <th>Correo</th>
            <th>codigo de pedido</th>
            <th id="envio">enviado</th>
            <th id="fecha">fecha</th>
            <th>enviar</th>
            <th>borrar</th>
        </thead>
        <tbody>
            {
                orders.map((data: apirocketInterfaz) => (


                    <tr>
                        <td>{data.correo}</td>
                        <td>{data.codigoPedido}</td>
                        <td class="enviado" id="enviado">
                            {data.sent && "true"}
                            {!data.sent && "false"}
                        </td>
                        <td class="fecha">{data.createdAt}</td>
                        <td id="enviar">
                            {" "}
                            <button type="button" id={data.id}>
                                enviar
                            </button>
                        </td>
                        <td id="borrar">
                            <button type="button" id={data.id}>
                                borrar
                            </button>
                        </td>
                    </tr>

                    
                ))
            }
        </tbody>
    </table>


</Layout>

<script>
    let tbody = document.querySelector('tbody')
    async function eventoDelegadoEnviar(e: Event) {
        let td = (e.target as HTMLElement).closest("td");
        if (!td) {
            return;
        }
        if (td.id != "enviar") {
            return;
        }
        let boton = td.querySelector("button");
        if (boton) {
            console.log();
            if (boton.id == null) {
                return;
            }
            let id = boton.id;
            try {
                const response = await fetch("/api/sendOrder", {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json",
                    },
                    body: JSON.stringify({ id }),
                });
                const result = await response.json();

                console.log("Respuesta del servidor:", result);

                if (result) {
                    //Cambio el texto de false a true
                    if (boton.parentElement == null) {
                        return;
                    }
                    if (boton.parentElement.parentElement == null) {
                        return;
                    }
                    let textoEnviar =
                        boton.parentElement.parentElement.querySelector(
                            "#enviado",
                        );
                    if (!textoEnviar) {
                        return;
                    }
                    textoEnviar.textContent = "true";
                }
            } catch (error) {
                console.error("Error en la petición:", error);
            }
        }
    }
    document.addEventListener("click", eventoDelegadoEnviar);

    async function eventoDelegadoBorrar(e: Event) {
        let td = (e.target as HTMLElement).closest("td");
        if (!td) {
            return;
        }
        if (td.id != "borrar") {
            return;
        }
        let boton = td.querySelector("button");
        if (boton) {
            console.log();
            if (boton.id == null) {
                return;
            }
            let id = boton.id;
            try {
                const response = await fetch("/api/deleteOrder", {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json",
                    },
                    body: JSON.stringify({ id }),
                });
                const result = await response.json();

                console.log("Respuesta del servidor:", result);

                if (result) {
                    //Cambio el texto de false a true
                    boton.parentElement?.parentElement?.remove();
                }
            } catch (error) {
                console.error("Error en la petición:", error);
            }
        }
    }
    document.addEventListener("click", eventoDelegadoBorrar);

