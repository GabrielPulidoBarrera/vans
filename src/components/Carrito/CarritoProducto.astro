---
import GeneralCarrusel from "@general/GeneralCarrusel.astro";

const { Nombre, Colores, cantidadMaxima, Precio, arrayImagenes, id, imagen, talla } =
  Astro.props;

console.log((cantidadMaxima))

---

<div class="flex flex-col border-b border-[rgb(225,225,225)]" x-data=`{cantidad: 1, precio: ${Precio}, cantidadMaxima: ${cantidadMaxima},}`>
  <div class="text-[rgb(127,89,59)] text-xs" x-show="cantidadMaxima <= 5" x-text="'quedan'+cantidadMaxima"></div>
  <div class="flex justify-between">
    <div>{Nombre}</div>
    <div class="precioValor" x-text="cantidad*precio+'€'"></div>
  </div>
  <div class="flex">
    <img
      class=" object-contain p-0 shrink-0 m-4"
      src={`${imagen}?w=150&format=auto`}
      alt=""
      loading="lazy"
    />
    <div class="text-[rgb(82,82,82)]">
      <div>{Colores}</div>
      <div>{talla}</div>
    </div>
  </div>
  <div class="flex justify-between" >
    <div class=" *:border *:px-4 flex *:w-20">
      <button @click="if(cantidad>0) cantidad--">-</button>
      <input type="number" :value="cantidad"/>
      <button @click="if (cantidad<cantidadMaxima) cantidad++">+</button>
    </div>
    <div class="underline text-xs">Guardar para despues</div>
  </div>
  </div>
