import Layout from "@layouts/Layout.astro";

let APIROCKET_ECOMMERCE_TOKEN = process.env.APIROCKET_ECOMMERCE_TOKEN;
if (!APIROCKET_ECOMMERCE_TOKEN) {
    APIROCKET_ECOMMERCE_TOKEN = import.meta.env.APIROCKET_ECOMMERCE_TOKEN;
}

let myQuery = `query MyQuery {
  Orders {
    correo
    codigoPedido
    cart
    sent
    id
    createdAt
  }
}





`;

async function fetchApirocket(query: String) {
    const options = {
        method: "POST",
        headers: {
            "Content-Type": "application/json",
            Authorization: `Bearer ${APIROCKET_ECOMMERCE_TOKEN}`,
        },
        body: JSON.stringify({ query }),
    };

    const data = await fetch("https://graphql.apirocket.io", options).then(
        (response) => response.json(),
    );
    //console.log(data);
    return data;
}

let orders = (await fetchApirocket(myQuery)).data.Orders;
//console.log(orders);

interface apirocketInterfaz {
    id: string;
    correo: string;
    carrito: string;
    sent: boolean;
    codigoPedido: number;
    createdAt: string;
}

