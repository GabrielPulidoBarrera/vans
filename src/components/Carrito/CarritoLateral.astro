---
import GeneralBotonPago from "@components/General/GeneralBotonPago.astro";
import GeneralBotonApple from "@components/General/GeneralBotonApple.astro";
const {} = Astro.props


---

<script>
import Alpine from "alpinejs";


</script>

<div class="flex flex-col gap-5">
<div class="accordionCarrito bg-[rgb(243,243,243)]" x-data="{ expanded: false }">
  <div @click="expanded = ! expanded"
    
    class="Open hover:cursor-pointer productBuy ms-6 px-3 py-2    flex justify-between "
  >
    Usa un codigo promocional
    <svg
  class="w-6 h-6 transition-all duration-150"
  :class="{ '-rotate-90': expanded, 'rotate-90': !expanded }"
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 32 32"
>
  <path
    fill="currentColor"
    d="M9.91 24.96 19.37 16 9.9 7.04l1.5-1.58L22.54 16 11.41 26.54l-1.5-1.58Z"
  ></path>
</svg>
  </div>
  <div x-show="expanded" x-collapse  class="mt-4 ml-4 flex pb-5">
    <input type="text" placeholder="Código promocional" class="bg-white w-full py-2 border">
    <button class="border px-6 mx-2 ">Aplicar</button>
  </div>
</div>


    <div class="bg-[rgb(243,243,243)] p-3" x-data="{precio: 0, subtotal: 0}" @precio-cambiar="precio=precio+$event.detail.cambio">
        <div class="border-dashed border-b border-[#9a9a9a]">
            <div class="mb-5">RESUMEN DE PEDIDO</div>
            
            <div class="flex justify-between mb-4">
                <div>Subtotal: (<span id="subtotal" x-text="$store.precioCantidad.cantidad"></span>)</div>
        <div x-text="$store.precioCantidad.precio+'€'"></div>
            </div>
            <div class="flex justify-between mb-1">
                <div class="flex items-center justify-center">Envío <svg
          class="w-4 h-4 ml-2"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 32 32"
          id="info3"
          ><path
            fill-rule="evenodd"
            d="M16 25a9 9 0 1 0 0-18 9 9 0 0 0 0 18Zm0 2a11 11 0 1 0 0-22 11 11 0 0 0 0 22Z"
            clip-rule="evenodd"></path><path
            fill-rule="evenodd"
            d="M16 22a1 1 0 0 1-1-1v-7a1 1 0 1 1 2 0v7a1 1 0 0 1-1 1Z"
            clip-rule="evenodd"></path><path
            d="M17 11a1 1 0 1 1-2 0 1 1 0 0 1 2 0Z"></path></svg
        ></div>
                <div>Gratuito</div>
            </div>
        <div class="text-xs">Envio Estándar: Entrega estimada: 4-5 días laborales</div>
        <div class="mb-3"> Devolución gratuita en 30 dias</div>
    </div>
    <div class="flex justify-between ">
        
        <div class=""> Total del pedido</div>
        <div x-text="$store.precioCantidad.precio+'€'"></div>
    </div>
    <div class="text-xs ">(21% IVA incluido)</div>
    
</div>


</div>

