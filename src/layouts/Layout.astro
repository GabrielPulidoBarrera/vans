---
import GeneralHeader from "../components/General/GeneralHeader.astro";
import Nav from "@general/GeneralNav.astro";
import Footer from "@general/GeneralFooter.astro";
import GeneralTicker from "@components/General/GeneralTicker.astro";
import GeneralCarritoLateral from "@components/General/GeneralCarritoLateral.astro";

const {title, lang, flag, arrayTexto, mostrarTicker = false, botonIA = true, mostrar=true, mostrarCarrito=true} = Astro.props
console.log(mostrarCarrito)
---





<GeneralHeader title={title} lang={lang} />
{mostrarTicker &&<GeneralTicker arrayTexto={arrayTexto} />}


  <body class="bg-white" x-data="carritoProductoAlpine" @open-carrito-menu.window="refreshCarrito"

x-init="meterAlpine(); $watch('carrito', (valor, valorAntiguo) => { subirCarrito(); })">






    <Nav botonIA={botonIA} mostrar={mostrar}/>
    <main>
    <slot>

    </slot>

    <div x-data={`{ mostrarCarrito: ${mostrarCarrito} }`} x-show="mostrarCarrito==true">
      <GeneralCarritoLateral></GeneralCarritoLateral>
    </div>

    
  </main>
    <Footer flag={flag}, mostrar={mostrar}/>

    <script>
      import lozad from 'lozad'
      import Alpine from 'alpinejs'
      import collapse from '@alpinejs/collapse'


      const observer = lozad(); // lazy loads elements with default selector as '.lozad'
      observer.observe();
      Alpine.plugin(collapse)


import Swiper from 'swiper';
import { Navigation } from 'swiper/modules';
import 'swiper/css';
import 'swiper/css/navigation';
import 'swiper/css/pagination';

  import clonar from "@utils/localStorage"
  

const stored = localStorage.getItem("carrito");
let carrito
if (stored!=null){
  carrito = JSON.parse(stored)
}

  Alpine.store("carritoCheckout", carrito);



let carritoProductoAlpine = {

  carrito: carrito,
  pagina: 'carrito',

    init() {
    // This runs automatically when the component is initialized
    console.log("Component initialized!");
    this.meterAlpine(); // you can call other methods here
  },

  meterAlpine(){
    console.log(carrito)
  },

    refreshCarrito() {
    const stored = localStorage.getItem('carrito');
    this.carrito = stored ? JSON.parse(stored) : [];
  },
   removeFromCarrito(producto: any) {
    this.carrito = this.carrito.filter((item: any) => 
      !(item.id === producto.id && item.talla === producto.talla && item.color === producto.color)
    );
    localStorage.setItem('carrito', JSON.stringify(this.carrito));
  },
    subirCarrito(){
  localStorage.setItem('carrito', JSON.stringify(this.carrito));

    }

}
Alpine.data('carritoProductoAlpine', () => carritoProductoAlpine)

   

let cantidad = 0;
let precio = 0;
    if(!Alpine.store('precioCantidad')){

      carrito.map((e: any) => {
        cantidad+=1;
        precio += e.cantidad*e.precio;

      })

      Alpine.store('precioCantidad', { cantidad: cantidad, precio: precio});
    }
  ;


    </script>
</body>